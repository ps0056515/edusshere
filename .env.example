DATABASE_URL=postgresql://edusphere:edusphere@127.0.0.1:55432/edusphere?schema=public

AUTH_SECRET="replace-with-long-random-string"
AUTH_TRUST_HOST="true"

AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

NEXTAUTH_URL="http://localhost:3000"

# Demo login (Demo / Demo123): on in development; in production set to 1 to allow, or 0 to force off.
# ENABLE_DEMO_LOGIN="1"

# AI Engine — counsellor calls POST /api/ai/chat (server). Required for most models:
# OPENAI_API_KEY="sk-..."
# Optional overrides: OPENAI_CHAT_MODEL, OPENAI_MODEL_GPT4O, OPENAI_MODEL_GEMINI_PROXY, OPENAI_MODEL_CLAUDE_PROXY
# For UI models labelled "Claude …" with real Anthropic API:
# ANTHROPIC_API_KEY="sk-ant-..."
# Optional: ANTHROPIC_MODEL_SONNET, ANTHROPIC_MODEL_OPUS
